APP_ENV=development
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional file path with accounts list
ACCOUNT_CONFIG_PATH=./accounts.json
BUDGETS_DB_PATH=./storage/budgets.db
FRONTEND_BASE_URL=http://localhost:5173
AUTH_COOKIE_NAME=ops_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
OAUTH_NONCE_COOKIE_NAME=ops_oauth_nonce
OAUTH_STATE_TTL_MINUTES=10
OAUTH_SESSION_TTL_MINUTES=1440
OAUTH_SESSION_REFRESH_TTL_MINUTES=1440
CSRF_COOKIE_NAME=ops_csrf
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_ENFORCE_COOKIE_AUTH=true
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_AUTH_MAX_REQUESTS=60
AUTH_RATE_LIMIT_INVITE_MAX_REQUESTS=30
AUTH_RATE_LIMIT_ADMIN_INVITE_MAX_REQUESTS=30
REQUEST_LOG_ENABLED=true
METRICS_ENABLED=true
OBSERVABILITY_PUBLIC=true
ENABLE_TEST_ENDPOINTS=true
API_DOCS_ENABLED=true

# Optional fallback account IDs (comma-separated)
META_ACCOUNT_IDS=
META_BUSINESS_IDS=
GOOGLE_CUSTOMER_IDS=
TIKTOK_ADVERTISER_IDS=

# Meta
META_ACCESS_TOKEN=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v19

# TikTok
TIKTOK_ACCESS_TOKEN=

# OAuth login providers (platform access)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://127.0.0.1:8000/auth/facebook/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
