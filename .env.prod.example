# Production template (copy to deployment secret store, do not commit real secrets)
APP_ENV=production
HOST=0.0.0.0
PORT=8000
API_BIND_PORT=8000
WEB_BIND_PORT=5173
PROM_BIND_PORT=9090
ALERTMGR_BIND_PORT=9093
GRAFANA_BIND_PORT=3001

# Only production frontend origins. No wildcard.
ALLOWED_ORIGINS=https://app.envidicy.com,https://admin.envidicy.com
FRONTEND_BASE_URL=https://app.envidicy.com
NEXT_PUBLIC_API_BASE=https://api.envidicy.com
NEXT_PUBLIC_ENABLE_TOKEN_LOGIN=false

ACCOUNT_CONFIG_PATH=./accounts.json
BUDGETS_DB_PATH=./storage/budgets.db

AUTH_COOKIE_NAME=ops_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none
OAUTH_NONCE_COOKIE_NAME=ops_oauth_nonce

# Session policy
OAUTH_STATE_TTL_MINUTES=10
OAUTH_SESSION_TTL_MINUTES=480
OAUTH_SESSION_REFRESH_TTL_MINUTES=480

# CSRF
CSRF_COOKIE_NAME=ops_csrf
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_ENFORCE_COOKIE_AUTH=true

# Auth route rate limits
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_AUTH_MAX_REQUESTS=60
AUTH_RATE_LIMIT_INVITE_MAX_REQUESTS=30
AUTH_RATE_LIMIT_ADMIN_INVITE_MAX_REQUESTS=30
REQUEST_LOG_ENABLED=true
METRICS_ENABLED=true

# Optional fallback account IDs (comma-separated)
META_ACCOUNT_IDS=
GOOGLE_CUSTOMER_IDS=
TIKTOK_ADVERTISER_IDS=

# Provider API credentials
META_ACCESS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
TIKTOK_ACCESS_TOKEN=

# OAuth providers for platform login
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://api.envidicy.com/auth/facebook/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.envidicy.com/auth/google/callback

# Observability dashboards
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
